# Lightroom Vision Service Configuration
# Copy this to .env and fill in your values

# Alibaba Cloud Coding Plan API Key (from Model Studio console)
# Format: sk-sp-xxxxx
ALIBABA_API_KEY=

# API Base URL for Coding Plan (Anthropic-compatible)
ALIBABA_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic

# Vision model to use (qwen3.5-plus or kimi-k2.5)
VISION_MODEL=qwen3.5-plus

# Service port
PORT=3456

# Enable debug logging (true/false)
DEBUG=false
